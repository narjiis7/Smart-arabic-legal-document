# انسخ الملف إلى .env وعدّل القيم (لا ترفع .env لجيت إن احتوى أسراراً)

# ——— وضع واجهة فقط (بدون باكند) — اختياري ———
# VITE_FRONTEND_ONLY=true
# عند التفعيل: علّق سطر VITE_API_BASE_URL أدناه؛ يُفعَّل تلقائياً سلوك تجريبي (مثل VITE_MOCK_AUTH).
# لإعادة الربط لاحقاً: احذف أو ضع VITE_FRONTEND_ONLY=false وفعّل VITE_API_BASE_URL و VITE_MOCK_AUTH=false

# عنوان الـ API فقط: نفس الدومين اللي يفتح Swagger، بدون /swagger وبدون / في النهاية
# إنتاج (DigitalOcean): https://legal-tech-system-q6to3.ondigitalocean.app
# Swagger: https://legal-tech-system-q6to3.ondigitalocean.app/swagger/index.html
# تطوير محلي عبر نفق: https://xxxx.trycloudflare.com (بدون /swagger)
# مثال غلط: ...ondigitalocean.app/swagger/index.html
#
# تسجيل الدخول في التطبيق: بريد + كلمة مرور → POST {VITE_EMAIL_LOGIN_PATH} (افتراضي /api/auth/login)
# مسار اختياري لـ Mini (مثل SuperQi): VITE_LOGIN_PATH=/api/mini/auth/login
#
# إن رجع توليد العقد / عقودي برمز 401: JWT من /api/auth/login قد لا يُقبل على /api/mini/*.
# - إن رد الدخول يحتوي miniAccessToken يُستخدم تلقائياً.
# - أو مسار POST ثانٍ (نفس جسم email/password): VITE_MINI_EMAIL_LOGIN_PATH=/api/mini/...
# - أو إن الباكند يقبل بريد+مرور على /api/mini/auth/login: VITE_MINI_AUTH_WITH_EMAIL=true
#
# ——— LegalTech (Swagger) — مسارات Auth ———
# دخول المستخدم المصغّر: POST /api/mini/auth/login + { "superQiToken": "..." } → accessToken + refreshToken
# دخول الموقع (بريد): POST /api/auth/login + { "email", "password" } → نفس الحقول (AuthResponseDto)
# المستخدم التجريبي (DbSeeder): user@example.com / user1234
# التطبيق يخزّن مسار التحديث تلقائياً: بعد دخول البريد يُستخدم POST /api/auth/refresh-token؛ بعد Mini يُستخدم /api/mini/auth/refresh-token (الجسم في الحالتين: JSON string = الريفريش)
#
# تجديد accessToken — يُستدعى عند 401 وعند فتح التطبيق:
# VITE_MINI_REFRESH_PATH=/api/mini/auth/refresh-token
# لا تستخدم VITE_MINI_REFRESH_BODY=object مع LegalTech mini refresh (السكيمة type: string)
# إن يريد باكند آخر كائناً: VITE_MINI_REFRESH_BODY=object أو pascal
# لتعطيل إعادة المحاولة بعد 401: VITE_MINI_REFRESH_ON_401=false
#
# تسجيل خروج الخادم (Swagger: POST /api/mini/auth/revoke-token + Bearer + نفس جسم الـ refresh):
# VITE_MINI_REVOKE_PATH=/api/mini/auth/revoke-token
# ملف المستخدم: GET /api/mini/auth/profile ثم احتياطي /api/mini/me
# VITE_MINI_PROFILE_PATH=/api/mini/auth/profile
#
# فحص الربط نقطة بنقطة (مخرجات في الطرفية): npm run api:verify
# فحص سريع لـ login: npm run api:login-status
#
# إذا الربط يشتغل مرة ومرة لا: حدّث الرابط إن كان نفق Cloudflare؛ أعد تشغيل npm run dev بعد .env؛
# فضّل دومين إنتاج ثابت؛ جرّب npm run api:verify عند الشك؛ الفرونت يعيد محاولة الشبكة مرة واحدة تلقائياً.
VITE_API_BASE_URL=https://legal-tech-system-q6to3.ondigitalocean.app

# أثناء npm run dev: إن تركت VITE_API_BASE_URL فارغاً، وجّه البروكسي لباكندك (بدون / في النهاية)
# مثال: VITE_API_PROXY_TARGET=https://localhost:7001
# VITE_API_PROXY_TARGET=

# للتجربة بدون باكند: ضع true — احذفها أو اجعلها false للاتصال الحقيقي
# VITE_MOCK_AUTH=true

# زر «إعادة ضبط الاستشارة» في صفحة الاستشارة (للتدريب مع المدرب) حتى مع build إنتاجي:
# VITE_SHOW_CONSULT_RESET=true
# (أثناء npm run dev يظهر الزر تلقائياً بدون هذا السطر)

# ——— تسجيل الدخول (بريد + كلمة مرور) ———
# مسار Swagger لـ login بالبريد (غالباً /api/auth/login أو /api/Auth/login)
# VITE_EMAIL_LOGIN_PATH=/api/auth/login
# إن طلب الباكند PascalCase: Email, Password
# VITE_EMAIL_LOGIN_BODY=pascal
#
# إن رفض الباكند جسم JSON بـ camelCase (توليد عقد + إرسال للتوقيع)، جرّب:
# VITE_MINI_CONTRACT_GENERATE_BODY=pascal
#
# ——— Mini app فقط — مرجع Swagger المباشر ———
# https://legal-tech-system-q6to3.ondigitalocean.app/swagger/index.html
# المخطط JSON: .../swagger/v1/swagger.json — DTOs صارمة (additionalProperties: false) للمسارات التالية:
#
# SimulatePaymentDto (POST /api/mini/payments/simulate): amount، consultationRequestId؟، generatedContractId؟ — بدون paymentContext
# تدفق توليد العقد في الواجهة: أولاً POST /contracts/generate ثم POST /payments/simulate مع { amount, generatedContractId } لربط الدفعة بالعقد (حسب وصف Swagger).
# GenerateContractDto (POST /api/mini/contracts/generate): templateId، data — بدون paymentId في المخطط المنشور
# CreateRequestDto (POST /api/mini/requests): serviceType، description، city، whatsAppNumber، isUrgent — بدون paymentId
# التقييمات (محاميي): GET /api/mini/reviews/lawyer/{lawyerProfileId} — POST /api/mini/reviews { consultationRequestId, rating, comment } + JWT
# إن طلب الباكند PascalCase للتقييم: VITE_MINI_REVIEW_BODY=pascal
#
# إن أردت إرسال حقول إضافية (باكند أحدث أو تجربة): فعّل صراحةً:
# VITE_MINI_PAYMENT_SEND_CONTEXT=true
# VITE_MINI_PAYMENT_CONTEXT_JSON_KEY=paymentContext
# VITE_MINI_CONTRACT_GENERATE_EXTRA_FIELDS=true
# VITE_MINI_CONTRACT_GENERATE_LINK_FIELD=PaymentId
# VITE_MINI_REQUEST_INCLUDE_PAYMENT_ID=true
#
# حقل data في LegalTech: خريطة مفاتيح → قيم نصية فقط (الفرونت يحوّل الأرقام والكائنات تلقائياً).
# قوالب: GET /api/mini/contracts/templates و GET .../templates/{id}/ready-data
# عقود المستخدم: GET /api/mini/contracts/my
#
# مساعد AI (الاستشارة الإجرائية): POST /api/mini/ai-chat + JWT — جسم { "message": "..." } — رد { reply, suggestedServiceType?, suggestedAction? }
# عند ضبط VITE_API_BASE_URL يُستخدم هذا المسار تلقائياً. لإجبار OpenAI/Groq من .env بدلاً من الخادم:
# VITE_CONSULT_AI_SOURCE=openai
# إن رفض الباكند camelCase للجسم: VITE_MINI_AI_CHAT_BODY=pascal
#
# عند فشل PDF على السيرفر (مثل LibreOffice غير مضبوط): بعد توليد عقد ناجح من هذا المتصفح
# تُحفظ حقولك محلياً؛ زر التحميل يفتح صفحة طباعة ببياناتك كاحتياطي.
# لتخطي POST /contracts/generate بالكامل واستخدام بياناتك فقط محلياً (تجربة):
# VITE_MINI_CONTRACT_CLIENT_DEMO=true

# ——— مساعد AI (واجهة مثل OpenAI: /v1/chat/completions) ———
# مثال OpenAI:
# VITE_AI_BASE_URL=https://api.openai.com/v1
# VITE_AI_API_KEY=sk-...
# VITE_AI_MODEL=gpt-4o-mini
#
# مثال Groq (مجاني للتجربة):
# VITE_AI_BASE_URL=https://api.groq.com/openai/v1
# VITE_AI_API_KEY=...
# VITE_AI_MODEL=llama-3.3-70b-versatile
#
# LM Studio محلي:
# VITE_AI_BASE_URL=http://localhost:1234/v1
#
# إجبار رد وهمي بدون استدعاء شبكة:
# VITE_AI_MOCK=true
#
# تحذير: المفتاح يظهر في المتصفح؛ للإنتاج مرّر الطلبات من باكندك.
#
# محامي المستخدم (صفحة «محاميي»): GET اختياري — افتراضي /api/mini/me/assigned-lawyer
# إن لم يكن المسار موجوداً على السيرفر (404)، التطبيق يستنتج المحامي من طلباتك التي فيها assignedLawyer.
# VITE_MINI_ASSIGNED_LAWYER_PATH=/api/mini/me/assigned-lawyer
# إظهار زر «تعيين محامٍ للمستخدم» في حسابي بدون دور Admin (تطوير فقط):
# VITE_DEV_ADMIN_LAWYER=true
